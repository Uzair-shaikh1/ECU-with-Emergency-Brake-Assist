#define F_CPU 14745600

#include <avr/io.h>
#include <util/delay.h>

// ---------------- MOTOR CONFIG ----------------

void motion_pin_config()
{
	DDRA = 0x0F;
	PORTA = 0x00;

	DDRL = 0x18;
	PORTL = 0x18;
}

// ---------------- TIMER5 PWM ----------------

void timer5_init()
{
	TCCR5B = 0x00;

	TCNT5H = 0xFF;
	TCNT5L = 0x01;

	OCR5AH = 0x00;
	OCR5AL = 0xFF;

	OCR5BH = 0x00;
	OCR5BL = 0xFF;

	TCCR5A = 0xA9;
	TCCR5B = 0x0B;
}

// ---------------- VELOCITY ----------------

void velocity(unsigned char left_motor, unsigned char right_motor)
{
	OCR5AL = right_motor;
	OCR5BL = left_motor;
}

// ---------------- ADC INIT ----------------

void adc_init()
{
	ADCSRA = 0x00;
	ADCSRB = 0x00;

	ADMUX = 0x20;

	ACSR = 0x80;

	ADCSRA = 0x86;
}

// ---------------- ADC READ ----------------

unsigned char ADC_Conversion(unsigned char ch)
{
	unsigned char a;

	if(ch > 7)
	{
		ADCSRB = 0x08;
	}

	ch = ch & 0x07;

	ADMUX = 0x20 | ch;

	ADCSRA |= 0x40;

	while((ADCSRA & 0x10) == 0);

	a = ADCH;

	ADCSRA |= 0x10;

	ADCSRB = 0x00;

	return a;
}

// ---------------- ROBOT MOTION ----------------

void forward()
{
	PORTA = 0x06;
}

void stop()
{
	PORTA = 0x00;
}

// ---------------- MAIN ----------------

int main(void)
{
	unsigned char front_ir;

	unsigned char left_wl;
	unsigned char center_wl;
	unsigned char right_wl;

	motion_pin_config();

	timer5_init();

	adc_init();

	// FULL SPEED
	velocity(255,255);

	while(1)
	{
		// FRONT IR SENSOR
		front_ir = ADC_Conversion(11);

		// WHITE LINE SENSORS
		left_wl   = ADC_Conversion(3);
		center_wl = ADC_Conversion(2);
		right_wl  = ADC_Conversion(1);

		// STOP CONDITIONS

		if( (front_ir > 80) ||

		(left_wl   > 120) ||
		(center_wl > 120) ||
		(right_wl  > 120) )
		{
			stop();
		}
		else
		{
			forward();
		}

		_delay_ms(20);
	}
}
